#!/bin/sh
# ─── Lock-Recon Pre-Commit Guard ─────────────────────────────────────────────
# Runs before every `git commit` to prevent junk files entering the repo.
# Install:  git config core.hooksPath .githooks  (already configured)
# ─────────────────────────────────────────────────────────────────────────────

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

echo ""
echo "Pre-commit guard running..."

FAIL=0

# Only check files being ADDED or MODIFIED (not deleted)
ADDED_OR_MODIFIED=$(git diff --cached --name-only --diff-filter=AM)

# ── 1. Reject diagnostic / one-off scripts being added ───────────────────────
for f in $ADDED_OR_MODIFIED; do
    basename=$(basename "$f")
    dir=$(dirname "$f")

    # Flag root-level test_*.mjs / test_*.js (not inside /test/)
    if echo "$basename" | grep -qE '^test_.*\.(mjs|js)$' && [ "$dir" = "." ]; then
        echo "  BLOCKED: root-level test script: $f"
        echo "    -> Move to /test/ if it belongs in the repo, or add to .gitignore"
        FAIL=1
    fi

    # Flag diagnostic files anywhere
    if echo "$basename" | grep -qE '^diag_|_diag\.(cjs|mjs|js)$'; then
        echo "  BLOCKED: diagnostic file: $f"
        echo "    -> Add to .gitignore or delete before committing"
        FAIL=1
    fi
done

# ── 2. Block log/output files being added ────────────────────────────────────
for f in $ADDED_OR_MODIFIED; do
    case "$f" in
        *.log|server_logs*|test_output*|scraper-error*|error.log)
            echo "  BLOCKED: log/output file being staged: $f"
            echo "    -> This file should be in .gitignore. Remove with: git rm --cached $f"
            FAIL=1
            ;;
    esac
done

# ── 3. Warn about untracked files that look important ────────────────────────
UNTRACKED=$(git ls-files --others --exclude-standard | grep -vE '^\.' | grep -v node_modules)
if [ -n "$UNTRACKED" ]; then
    echo "  WARNING: Untracked files exist (review before next commit):"
    echo "$UNTRACKED" | while read -r uf; do
        echo "    - $uf"
    done
fi

# ── 4. Remind about version bump when public/ changes ────────────────────────
PUBLIC_CHANGED=$(echo "$ADDED_OR_MODIFIED" | grep -c '^public/' || true)
VERSION_CHANGED=$(echo "$ADDED_OR_MODIFIED" | grep -c 'version\.txt' || true)
if [ "$PUBLIC_CHANGED" -gt 0 ] && [ "$VERSION_CHANGED" -eq 0 ]; then
    echo "  WARNING: public/ files changed but version.txt NOT updated"
    echo "    -> Remember the Dual Version Bump rule (patch +1 minimum)"
fi

if [ "$FAIL" -eq 0 ]; then
    echo "  Pre-commit guard passed"
fi
echo ""

exit $FAIL
