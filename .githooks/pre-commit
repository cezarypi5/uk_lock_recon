#!/bin/sh
# ─── Lock-Recon Pre-Commit Guard v2 ──────────────────────────────────────────
# MANDATORY on every commit — no exceptions, no chore: bypasses.
# Configured via: git config core.hooksPath .githooks
# ─────────────────────────────────────────────────────────────────────────────

echo ""
echo "========================================"
echo "  Lock-Recon Pre-Commit Guard v2"
echo "========================================"

FAIL=0
ADDED_OR_MODIFIED=$(git diff --cached --name-only --diff-filter=AM)
ALL_STAGED=$(git diff --cached --name-only)

# ── RULE 1: Version bump is MANDATORY on every commit ────────────────────────
VERSION_CHANGED=$(echo "$ALL_STAGED" | grep -c 'version\.txt' || true)
if [ "$VERSION_CHANGED" -eq 0 ]; then
    echo ""
    echo "  [BLOCKED] No version.txt bump detected."
    echo ""
    echo "  Every commit MUST include a version bump. No exceptions."
    echo "  Steps:"
    echo "    1. Increment version in version.txt       (patch = x.y.N+1)"
    echo "    2. Increment version in public/version.txt"
    echo "    3. Update <meta name=\"version\"> in public/index.html"
    echo "    4. Then re-stage and commit."
    echo ""
    FAIL=1
fi

# ── RULE 2: Reject root-level test/diagnostic scripts ────────────────────────
for f in $ADDED_OR_MODIFIED; do
    base=$(basename "$f")
    dir=$(dirname "$f")

    if echo "$base" | grep -qE '^test_.*\.(mjs|js)$' && [ "$dir" = "." ]; then
        echo "  [BLOCKED] Root-level test script staged: $f"
        echo "    -> Move to /test/ or add to .gitignore"
        FAIL=1
    fi

    if echo "$base" | grep -qE '^diag_|_diag\.(cjs|mjs|js)$'; then
        echo "  [BLOCKED] Diagnostic file staged: $f"
        echo "    -> Add to .gitignore or delete before committing"
        FAIL=1
    fi
done

# ── RULE 3: Block log and output files ───────────────────────────────────────
for f in $ADDED_OR_MODIFIED; do
    case "$f" in
        *.log|server_logs*|test_output*|scraper-error*|error.log|deploy_debug*|db_test_log*|debug_log*)
            echo "  [BLOCKED] Log/output file staged: $f"
            echo "    -> Run: git rm --cached $f  then add to .gitignore"
            FAIL=1
            ;;
    esac
done

# ── RULE 4: Smoke test reminder (cannot automate, but make it visible) ────────
echo ""
echo "  [CHECKLIST] Before this commit is valid, confirm:"
echo "    [ ] Smoke test run against live site (test/smoke_test.cjs)"
echo "    [ ] live site version.txt matches new version"
echo "    [ ] No console errors on lock-recon.web.app"
echo ""

# ── RULE 5: Warn about untracked files ───────────────────────────────────────
UNTRACKED=$(git ls-files --others --exclude-standard | grep -vE '^\.|node_modules')
if [ -n "$UNTRACKED" ]; then
    echo "  [WARNING] Untracked files (review — should these be committed or gitignored?):"
    echo "$UNTRACKED" | while read -r uf; do echo "    - $uf"; done
    echo ""
fi

if [ "$FAIL" -eq 0 ]; then
    echo "  [PASSED] All guards passed. Committing..."
fi
echo "========================================"
echo ""

exit $FAIL
