#!/bin/sh
# ─── Lock-Recon Pre-Commit Guard v3 ──────────────────────────────────────────
# MANDATORY on every commit. Runs automated smoke test. No human bypass.
# Configured via: git config core.hooksPath .githooks  (already set)
# ─────────────────────────────────────────────────────────────────────────────

echo ""
echo "========================================"
echo "  Lock-Recon Pre-Commit Guard v3"
echo "========================================"

FAIL=0
ADDED_OR_MODIFIED=$(git diff --cached --name-only --diff-filter=AM)
ALL_STAGED=$(git diff --cached --name-only)

# ── RULE 1: Version bump is MANDATORY on every commit ────────────────────────
VERSION_CHANGED=$(echo "$ALL_STAGED" | grep -c 'version\.txt' || true)
if [ "$VERSION_CHANGED" -eq 0 ]; then
    echo ""
    echo "  [BLOCKED] No version.txt bump detected."
    echo ""
    echo "  Every commit MUST include a version bump. No exceptions."
    echo "  Steps:"
    echo "    1. Increment version in version.txt       (patch = x.y.N+1)"
    echo "    2. Increment version in public/version.txt"
    echo "    3. Update <meta name=\"version\"> in public/index.html"
    echo "    4. Re-stage all three files and commit."
    echo ""
    FAIL=1
fi

# ── RULE 2: Reject root-level test/diagnostic scripts ────────────────────────
for f in $ADDED_OR_MODIFIED; do
    base=$(basename "$f")
    dir=$(dirname "$f")

    if echo "$base" | grep -qE '^test_.*\.(mjs|js)$' && [ "$dir" = "." ]; then
        echo "  [BLOCKED] Root-level test script staged: $f"
        echo "    -> Move to /test/ or add to .gitignore"
        FAIL=1
    fi

    if echo "$base" | grep -qE '^diag_|_diag\.(cjs|mjs|js)$'; then
        echo "  [BLOCKED] Diagnostic file staged: $f"
        echo "    -> Add to .gitignore or delete before committing"
        FAIL=1
    fi
done

# ── RULE 3: Block log and output files ───────────────────────────────────────
for f in $ADDED_OR_MODIFIED; do
    case "$f" in
        *.log|server_logs*|test_output*|scraper-error*|error.log|deploy_debug*|db_test_log*|debug_log*)
            echo "  [BLOCKED] Log/output file staged: $f"
            echo "    -> Run: git rm --cached $f  then add to .gitignore"
            FAIL=1
            ;;
    esac
done

# ── RULE 4: Warn about untracked files ───────────────────────────────────────
UNTRACKED=$(git ls-files --others --exclude-standard | grep -vE '^\.|node_modules')
if [ -n "$UNTRACKED" ]; then
    echo "  [WARNING] Untracked files (should these be committed or gitignored?):"
    echo "$UNTRACKED" | while read -r uf; do echo "    - $uf"; done
    echo ""
fi

# ── RULE 5: Block before structural errors are confirmed ─────────────────────
# Exit early if rules 1-4 failed — don't waste time running the smoke test
if [ "$FAIL" -ne 0 ]; then
    echo ""
    echo "  [BLOCKED] Fix the above issues first, then re-commit."
    echo "========================================"
    exit 1
fi

# ── RULE 6: AUTOMATED SMOKE TEST (mandatory — not a checklist prompt) ─────────
echo ""
echo "  [SMOKE TEST] Running functional smoke test against live site..."
echo "  (Tests app health: cards load, filters work, no JS errors.)"
echo "  (Version check is skipped here — live is 1 version behind by design.)"
echo "  (Version check runs automatically after deployment via post-deploy step.)"
echo ""

node test/smoke_test.cjs --functional
SMOKE_EXIT=$?

if [ "$SMOKE_EXIT" -ne 0 ]; then
    echo ""
    echo "  [BLOCKED] Smoke test FAILED. Commit aborted."
    echo ""
    echo "  The smoke test must pass with zero critical errors before committing."
    echo "  Fix the failures above, then re-run:  node test/smoke_test.cjs"
    echo "========================================"
    exit 1
fi

echo ""
echo "  [PASSED] All guards passed. Committing..."
echo "========================================"
echo ""

exit 0
